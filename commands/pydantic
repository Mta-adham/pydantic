#!/usr/bin/env bash
set -euo pipefail

HUB="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck disable=SC1091
source "${HUB}/scripts/env.sh"

usage() {
    cat <<'EOF'
Pydantic benchmark hub

  ./compile|benchmark|test [task]   Artemis entrypoints (active task if omitted)
  commands/compile [task]           same as ./compile
  commands/prepare [task]           setup eval workspace only
  commands/benchmark [task]         GSO Docker performance eval
  commands/test [task]              GSO correctness tests
  commands/reset [task]             discard edits in project/
  commands/pull-images [task]       pull pinned GSO Docker images
  commands/verify-images [task]     verify local image digests
  commands/pin-images [task]        pin digest in benchmark.yaml

Or: ./compile|benchmark|test|... [task]

Uses your current shell Python environment (pip install -r requirements.txt).
EOF
    pydantic_export_paths
    pydantic_list_tasks 2>/dev/null | awk -F'\t' '{print "  " $1}' || true
    exit "${1:-0}"
}

[[ $# -gt 0 ]] || usage 1

case "$1" in
    -h|--help|help) usage 0 ;;
    compile|prepare|benchmark|test|reset)
        exec "${HUB}/scripts/run.sh" "$@"
        ;;
    pull-images|verify-images|pin-images)
        exec "${HUB}/scripts/images.sh" "$@"
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage 1
        ;;
esac
