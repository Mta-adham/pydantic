#!/usr/bin/env bash
# Unified pydantic benchmark CLI.
#
#   ./pydantic compile|benchmark|test|reset [task_id] [options]
#   ./pydantic images pull|verify|pin [task_id] [options]
set -euo pipefail

HUB_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck disable=SC1091
source "${HUB_ROOT}/scripts/env.sh"

usage() {
    cat <<'EOF'
Pydantic benchmark hub

Workflow:
  ./pydantic prepare [task_id]           # setup eval + checkout project/ (optional)
  ./pydantic compile [task_id]           # prepare if needed, then build patch
  ./pydantic benchmark [task_id] [--reuse-report] [--keep-image]
  ./pydantic test [--from-benchmark] [task_id]
  ./pydantic reset [task_id]

Images (digest-pinned from benchmarks/*/benchmark.yaml):
  ./pydantic images pull [task_id ...]
  ./pydantic images verify [--force] [task_id ...]
  ./pydantic images pin [task_id ...]

Same commands live under commands/ (e.g. commands/compile).
EOF
    exit "${1:-0}"
}

[[ $# -gt 0 ]] || usage 1
case "$1" in
    -h|--help) usage 0 ;;
    compile|prepare|benchmark|test|reset)
        exec "${HUB_ROOT}/scripts/run.sh" "$@"
        ;;
    images)
        shift
        exec "${HUB_ROOT}/scripts/images.sh" "$@"
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage 1
        ;;
esac
