# Per-task eval workspaces — only benchmark.yaml (+ optional output/) are tracked.
# prompt.md and OPTIMIZATION.md are runtime / Artemis-injected, not committed.
eval/*/baseline/
eval/*/expert/
eval/*/metadata.json
eval/*/patch.diff
eval/*/predictions.jsonl
eval/*/prompt.md
eval/*/OPTIMIZATION.md

# Cached HuggingFace instance payloads
eval/*/instance.json

# Latest benchmark copy at hub root (regenerated each run; per-task copies in eval/*/output/ are tracked)
/artemis_results.json
/artemis_results_robust.json
/tests_artemis_results.json
/summary.txt

# Harness logs
logs/

# Vendored upstream source (tracked); nested clone metadata is not
project/.git/

# Local Python environment
.venv/

# Python
__pycache__/
*.py[cod]
