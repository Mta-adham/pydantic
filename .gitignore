# Per-task eval workspaces (generated at run time)
eval/

# Legacy active-task pointer (prefer .gso_task_id)
.active_task

# Cached HuggingFace instance payloads (benchmark defs are tracked)
benchmarks/**/instance.json

# Latest benchmark copy (regenerated each run)
artemis_results.json

# Harness logs
logs/

# Local git metadata for task switching (vendored files are tracked above)
project/.git/

# Local Python environment
.venv/

# Python
__pycache__/
*.py[cod]
